# ---------------------------------------------------------------------------
# DAINO frontend-industriale — environment template
# ---------------------------------------------------------------------------
# Copia in .env.local e compila i valori. Tutto ciò che inizia con VITE_*
# viene esposto al bundle del browser — NON metterci segreti.
# ---------------------------------------------------------------------------

# Base URL del backend definitivo (daino-backend-definitivo).
# In dev: localhost:8001. In prod: l'URL pubblico del solver.
VITE_API_BASE_URL=http://localhost:8001

# ---------------------------------------------------------------------------
# Server-only (BFF) — NON usare VITE_ prefix.
# Configurato in Cloudflare Workers / Nitro env, mai esposto al client.
# Verrà popolato dalla Wave 2 in poi.
# ---------------------------------------------------------------------------

# Anthropic API key — server-side only (BFF Explainer/Advisor in Wave 2+).
# Populate in .env.local (gitignored via *.local) or via wrangler secrets in prod.
ANTHROPIC_API_KEY=

# Per-IP rate limit on /api/explain and /api/advise (requests per hour).
DAINO_BFF_RATE_LIMIT_PER_HOUR=10

# In dev, the BFF bypasses rate limit for 127.0.0.1 / ::1 / 'local' so e2e
# tests and stress runners can burst > 10/h. Set to "0" to enforce the limit
# even in dev. In production (NODE_ENV=production) the bypass is OFF
# unconditionally regardless of this flag.
# DAINO_BFF_RATE_LIMIT_BYPASS_LOCAL=1
