# ---------------------------------------------------------------------------
# DAINO frontend-industriale — environment template
# ---------------------------------------------------------------------------
# Copia in .env.local e compila i valori. Tutto ciò che inizia con VITE_*
# viene esposto al bundle del browser — NON metterci segreti.
# ---------------------------------------------------------------------------

# Base URL del backend definitivo (daino-backend-definitivo).
# In dev: localhost:8001. In prod: l'URL pubblico del solver.
VITE_API_BASE_URL=http://localhost:8001

# ---------------------------------------------------------------------------
# Server-only (BFF) — NON usare VITE_ prefix.
# Configurato in Cloudflare Workers / Nitro env, mai esposto al client.
# Verrà popolato dalla Wave 2 in poi.
# ---------------------------------------------------------------------------

# Anthropic API key — server-side only (BFF Explainer/Advisor in Wave 2+).
# Populate in .env.local (gitignored via *.local) or via wrangler secrets in prod.
ANTHROPIC_API_KEY=

# Per-IP rate limit on /api/explain, /api/advise, and /api/apply-whatif
# (requests per hour). Production should set this explicitly via secrets
# rather than rely on the 10/h default.
DAINO_BFF_RATE_LIMIT_PER_HOUR=10

# In dev (NODE_ENV !== 'production') the BFF bypasses the rate limit for
# ALL IPs so e2e tests, stress runners, and dogfooding via vite --host
# on a LAN IP don't trip the 10/h cap while iterating. Set to "0" to
# enforce the limit even in dev. In production the bypass is OFF
# unconditionally regardless of this flag.
# DAINO_BFF_RATE_LIMIT_BYPASS_LOCAL=1

# ---------------------------------------------------------------------------
# Wave 16.2 — shared secret for backend internal API auth.
# The SAME value must be set in daino-backend-definitivo's DAINO_INTERNAL_SECRET.
# Generate with: openssl rand -hex 32
# In dev: any non-empty value works (both ends must match).
# In prod: rotate via secrets manager; never commit the real value.
# When unset, the BFF skips the deterministic extractor and falls back to Opus.
# ---------------------------------------------------------------------------
DAINO_INTERNAL_SECRET=
